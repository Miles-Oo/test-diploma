  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  dialogueText: "Odejd\u017A!"
  startNode:
    npcText: Czy mozesz byc ciszej?
    options:
    - optionText: Oczywiscie, za 5 eurogabek
      nextNode:
        npcText: Masz i siedz cicho
        options:
        - optionText: 1
          nextNode:
            npcText: 1
            options: []
        - optionText: 1
          nextNode:
            npcText: 1
            options: []
        - optionText: 1
          nextNode:
            npcText: 1
            options: []
        - optionText: 1
          nextNode:
            npcText: 1
            options: []
    - optionText: Kim jestes?
      nextNode:
        npcText: Doigrasz sie ziom
        options:
        - optionText: 2
          nextNode:
            npcText: 2
            options: []
    - optionText: Nie krzycz
      nextNode:
        npcText: "Masz bana na k\u0105kuter"
        options:
        - optionText: 3
          nextNode:
            npcText: 3
            options: []
  lastNodeUsed:
    npcText: 
    options: []
