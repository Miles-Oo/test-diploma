  startNode:
    npcText: 
    options:
    - optionText: "Kto wy\u0142\u0105czy\u0142 zasilanie na pi\u0119trze?"
      nextNode:
        npcText: Ja, ale chwilowo.
        options:
        - optionText: Dlaczego?
          nextNode:
            npcText: "Bo \u015Bwiat\u0142o na klatce si\u0119 \u015Bwieci\u0142o
              w dzie\u0144. To po co ma si\u0119 marnowa\u0107?"
            options:
            - optionText: "Wy\u0142\u0105czy\u0142 pan nie to, co trzeba."
              nextNode:
                npcText: "Szczeg\xF3\u0142y, panie. Pr\u0105d to pr\u0105d."
