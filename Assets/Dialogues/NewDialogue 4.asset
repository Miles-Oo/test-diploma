  startNode:
    npcText: "O, dzia\u0142a. Czyli jednak da\u0142o si\u0119 to zrobi\u0107."
    options:
    - optionText: "Da\u0142o si\u0119, bo przesta\u0142 pan przeszkadza\u0107."
      nextNode:
        npcText: "No dobra, mo\u017Ce troch\u0119 si\u0119 pospieszy\u0142em."
        options: []
      unlockMiniGame: {fileID: 0}
      rememberNode: 0
    - optionText: Tak, magia. Na pewno nie naprawa.
      nextNode:
        npcText: Sarkazm to pan ma po tym internecie chyba.
        options: []
      unlockMiniGame: {fileID: 0}
      rememberNode: 0
    - optionText: "Prosz\u0119 niczego wi\u0119cej nie rusza\u0107."
      nextNode:
        npcText: "Dobrze, dobrze. Chocia\u017C i tak by\u0142o \u017Ale zamontowane."
        options: []
      unlockMiniGame: {fileID: 0}
      rememberNode: 0
